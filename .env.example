# Copy to .env.local and fill in real values. Never commit .env or .env.local.
# Database (Postgres). Required for Auth (NextAuth + Prisma adapter) and dashboard/API.
DATABASE_URL="postgresql://user:password@host:5432/postgres?sslmode=require"
# Supabase: use the Connection pooler (Transaction mode, port 6543) from Project Settings → Database,
# not the direct URL (db.xxx.supabase.co:5432). Pooler avoids "Can't reach database server" in Next.js.
# After pause/restore, re-copy the connection string and password from the dashboard.
# For local dev only: set to "true" if you get "self-signed certificate in certificate chain" (e.g. Supabase)
# DATABASE_SSL_ACCEPT_INSECURE="true"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Auth (NextAuth)
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub repo connection (OAuth for listing user repos)
GITHUB_REPO_CLIENT_ID=""
GITHUB_REPO_CLIENT_SECRET=""

# 32-byte key (base64) for encrypting GitHub tokens at rest. Generate with: openssl rand -base64 32
# Then paste the output as the value below (required for "Connect GitHub" on dashboard).
GITHUB_TOKEN_ENCRYPTION_KEY=""
